extends ../../layouts/default.pug

block main
  .container-fluid.py-4
    h1.h3.mb-4.text-gray-800 <i class="fas fa-chart-line mr-2 text-primary"></i> Tổng quan doanh thu

    //- KHỐI 1: DOANH THU TÀI CHÍNH
    .row.mb-4
      //- Doanh thu thực tế (Thành công)
      .col-xl-6.col-md-6.mb-4
        .card.border-left-success.shadow-sm.h-100.py-2
          .card-body
            .row.no-gutters.align-items-center
              .col.mr-2
                .text-xs.font-weight-bold.text-success.text-uppercase.mb-1 TỔNG DOANH THU THỰC TẾ
                .h4.mb-0.font-weight-bold.text-gray-800 #{statistic.order.totalRevenue.toLocaleString("vi-VN")}đ
                .text-xs.text-muted.mt-2 Đã hoàn thành #{statistic.order.success} đơn hàng
              .col-auto
                i.fas.fa-money-check-alt.fa-2x.text-gray-300

      //- Tổng chiết khấu Voucher
      .col-xl-6.col-md-6.mb-4
        .card.border-left-danger.shadow-sm.h-100.py-2
          .card-body
            .row.no-gutters.align-items-center
              .col.mr-2
                .text-xs.font-weight-bold.text-danger.text-uppercase.mb-1 TỔNG GIẢM GIÁ VOUCHER
                .h4.mb-0.font-weight-bold.text-gray-800 -#{statistic.order.totalDiscount.toLocaleString("vi-VN")}đ
                .text-xs.text-muted.mt-2 Ngân sách khuyến mãi đã sử dụng
              .col-auto
                i.fas.fa-ticket-alt.fa-2x.text-gray-300

    //- KHỐI 2: TRẠNG THÁI ĐƠN HÀNG (Bổ sung)
    .row.mb-4
      .col-12
        .card.shadow-sm.border-0
          .card-header.bg-white.py-3
            h6.m-0.font-weight-bold.text-primary <i class="fas fa-tasks mr-2"></i> Trạng thái đơn hàng (Tổng số: #{statistic.order.total} đơn)
          .card-body
            .row.text-center
              .col-md-2.col-6.mb-3
                .p-3.bg-light.rounded.border
                  .text-warning.h4.mb-1.font-weight-bold #{statistic.order.pending}
                  .small.font-weight-bold Chờ duyệt
              .col-md-2.col-6.mb-3
                .p-3.bg-light.rounded.border
                  .text-info.h4.mb-1.font-weight-bold #{statistic.order.confirm}
                  .small.font-weight-bold Đã xác nhận
              .col-md-2.col-6.mb-3
                .p-3.bg-light.rounded.border
                  .text-primary.h4.mb-1.font-weight-bold #{statistic.order.delivering}
                  .small.font-weight-bold Đang giao
              .col-md-3.col-6.mb-3
                .p-3.bg-success-light.rounded.border.border-success
                  .text-success.h4.mb-1.font-weight-bold #{statistic.order.success}
                  .small.font-weight-bold Hoàn thành
              .col-md-3.col-12.mb-3
                .p-3.bg-danger-light.rounded.border.border-danger
                  .text-danger.h4.mb-1.font-weight-bold #{statistic.order.cancel}
                  .small.font-weight-bold Đã hủy

    //- KHỐI 3: BẢNG DOANH THU THEO THÁNG
    .row.mb-4
      .col-12
        .card.shadow-sm.border-0
          .card-header.bg-white.py-3
            h6.m-0.font-weight-bold.text-primary <i class="fas fa-calendar-alt mr-2"></i> Chi tiết doanh thu theo tháng
          .card-body
            table.table.table-hover.mb-0
              thead.thead-light
                tr
                  th Tháng/Năm
                  th.text-right Doanh thu thành công
              tbody
                if (statistic.order.monthlyRevenue.length > 0)
                  each item in statistic.order.monthlyRevenue
                    tr
                      td.font-weight-bold #{item.label}
                      td.text-right.text-success.font-weight-bold #{item.value.toLocaleString("vi-VN")}đ
                else
                  tr
                    td(colspan="2" class="text-center text-muted") Chưa có dữ liệu doanh thu thành công.

    //- KHỐI 4: THỐNG KÊ THỰC THỂ (Sản phẩm, Danh mục, Khách hàng, Voucher)
    .row
      - 
        var entities = [
          { label: 'Sản phẩm', data: statistic.product, color: 'info', icon: 'fa-box' },
          { label: 'Danh mục', data: statistic.categoryProduct, color: 'secondary', icon: 'fa-list' },
          { label: 'Voucher', data: statistic.voucher, color: 'danger', icon: 'fa-gift' },
          { label: 'Khách hàng', data: statistic.user, color: 'warning', icon: 'fa-users' }
        ]
      each entity in entities
        .col-md-3.mb-4
          .card.shadow-sm.border-0.h-100
            .card-body
              .d-flex.justify-content-between.mb-3
                h6.font-weight-bold #{entity.label}
                i(class=`fas ${entity.icon} text-${entity.color}`)
              .h3.font-weight-bold #{entity.data.total}
              .progress.mb-2(style="height: 4px;")
                - var percent = entity.data.total > 0 ? (entity.data.active / entity.data.total) * 100 : 0
                .progress-bar(class=`bg-${entity.color}` style=`width: ${percent}%`)
              .d-flex.justify-content-between.small.mt-2
                span.text-success <i class="fas fa-circle mr-1" style="font-size: 8px;"></i> Hoạt động: #{entity.data.active}
                span.text-danger <i class="fas fa-circle mr-1" style="font-size: 8px;"></i> Khóa: #{entity.data.inactive}

  style.
    .border-left-success { border-left: .25rem solid #28a745 !important; }
    .border-left-danger { border-left: .25rem solid #dc3545 !important; }
    .bg-success-light { background-color: #f0fff4 !important; }
    .bg-danger-light { background-color: #fff5f5 !important; }