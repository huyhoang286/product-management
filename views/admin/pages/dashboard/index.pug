extends ../../layouts/default.pug

block main
    h1.mb-4.font-weight-bold TỔNG QUAN HỆ THỐNG

    .row.mb-4
        .col-md-3
            .card.bg-success.text-white.shadow-sm.h-100
                .card-body
                    h5.card-title Doanh Thu Thành Công
                    h3.font-weight-bold #{statistic.order.totalRevenue.toLocaleString("vi-VN")} đ
                    i.fas.fa-money-bill-wave.fa-2x.position-absolute(style="right: 20px; bottom: 20px; opacity: 0.3;")
        .col-md-3
            .card.bg-primary.text-white.shadow-sm.h-100
                .card-body
                    h5.card-title Tổng Đơn Hàng
                    h3.font-weight-bold #{statistic.order.total} đơn
                    i.fas.fa-shopping-cart.fa-2x.position-absolute(style="right: 20px; bottom: 20px; opacity: 0.3;")
        .col-md-3
            .card.bg-warning.text-dark.shadow-sm.h-100
                .card-body
                    h5.card-title Đang Xử Lý
                    h3.font-weight-bold #{statistic.order.pending} đơn
                    i.fas.fa-spinner.fa-2x.position-absolute(style="right: 20px; bottom: 20px; opacity: 0.3;")
        .col-md-3
            .card.bg-danger.text-white.shadow-sm.h-100
                .card-body
                    h5.card-title Đơn Hủy
                    h3.font-weight-bold #{statistic.order.cancel} đơn
                    i.fas.fa-times-circle.fa-2x.position-absolute(style="right: 20px; bottom: 20px; opacity: 0.3;")

    .row
        .col-md-8
            .card.shadow-sm.mb-4
                .card-header.bg-light.font-weight-bold
                    i.fas.fa-chart-bar.mr-2
                    | Biểu đồ Doanh thu năm nay
                .card-body
                    canvas#revenueChart(width="100%" height="45")

        .col-md-4
            .card.shadow-sm.mb-4
                .card-header.bg-light.font-weight-bold
                    i.fas.fa-box.mr-2
                    | Thống kê Sản phẩm
                .card-body
                    p <b>Tổng số:</b> <span class="badge badge-secondary ml-2">#{statistic.product.total}</span>
                    p <b>Đang kinh doanh:</b> <span class="badge badge-success ml-2">#{statistic.product.active}</span>
                    p <b>Dừng kinh doanh:</b> <span class="badge badge-danger ml-2">#{statistic.product.inactive}</span>

            .card.shadow-sm
                .card-header.bg-light.font-weight-bold
                    i.fas.fa-users.mr-2
                    | Khách hàng (Users)
                .card-body
                    p <b>Tổng tài khoản:</b> <span class="badge badge-secondary ml-2">#{statistic.user.total}</span>
                    p <b>Đang hoạt động:</b> <span class="badge badge-success ml-2">#{statistic.user.active}</span>
                    p <b>Bị khóa:</b> <span class="badge badge-danger ml-2">#{statistic.user.inactive}</span>

    script(src="https://cdn.jsdelivr.net/npm/chart.js")
    
    script.
        const revenueData = !{revenueByMonth};

        const ctx = document.getElementById('revenueChart').getContext('2d');
        
        const myChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4', 'Tháng 5', 'Tháng 6', 'Tháng 7', 'Tháng 8', 'Tháng 9', 'Tháng 10', 'Tháng 11', 'Tháng 12'],
                datasets: [{
                    label: 'Doanh thu (VNĐ)',
                    data: revenueData, 
                    backgroundColor: 'rgba(54, 162, 235, 0.5)', 
                    borderColor: 'rgba(54, 162, 235, 1)',      
                    borderWidth: 1
                }]
            },
            options: {
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });