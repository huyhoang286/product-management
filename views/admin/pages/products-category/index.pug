extends ../../layouts/default.pug

block main
  h1.mb-4 Danh mục sản phẩm

  .card.mb-3
    .card-header Danh sách
    .card-body
      .row
        .col-8
        .col-4.text-right
          a(
            href=`/admin/products-category/create`
            class="btn btn-outline-success"
          ) + Thêm mới

      table.table.table-hover.table-sm.mt-3
        thead
          tr
            th STT
            th Hình ảnh
            th Tiêu đề
            th Vị trí
            th Trạng thái
            th Hành động
        tbody
          each item, index in records
            tr
              td #{index + 1}
              td
                img(
                  src=item.thumbnail
                  alt=item.title
                  width="100px"
                  height="auto"
                )
              td #{item.title}
              td
                input(
                  type="number"
                  value=item.position
                  style="width: 60px"
                  min="1"
                  name="position"
                )
              td
                if (item.status === "active")
                  a(href="javascript:;" class="badge badge-success") Hoạt động
                else
                  a(href="javascript:;" class="badge badge-danger") Dừng hoạt động
              td
                a(
                  href=`/admin/products-category/edit/${item.id}`
                  class="btn btn-warning btn-sm"
                ) Sửa
                button(
                  class="btn btn-danger btn-sm ml-1"
                ) Xóa