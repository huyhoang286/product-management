extends ../../layouts/default.pug

block main
  h1(class="mb-4") #{pageTitle}

  .card.shadow-sm
    .card-body
      form(
        id="form-create-voucher" 
        data-path=`${prefixAdmin}/vouchers/create`
      )
        .row
          .col-md-6
            .form-group
              label(for="code") Mã giảm giá
              input(type="text" class="form-control" name="code" required placeholder="VD: SALE50")
            .form-group
              label(for="discountPercentage") % Giảm giá (1-100)
              input(type="number" class="form-control" name="discountPercentage" required min="1" max="100")
            .form-group
              label(for="minOrderValue") Đơn tối thiểu (VNĐ)
              input(type="number" class="form-control" name="minOrderValue" value="0" required min="0")
          .col-md-6
            .form-group
              label(for="quantity") Số lượng mã phát hành
              input(type="number" class="form-control" name="quantity" required min="1")
            .form-group
              label(for="expireAt") Ngày hết hạn
              input(type="date" class="form-control" name="expireAt" required)
            .form-group
              label Trạng thái
              div
                .form-check.form-check-inline
                  input(type="radio" class="form-check-input" id="statusActive" name="status" value="active" checked)
                  label(for="statusActive" class="form-check-label") Hoạt động
                .form-check.form-check-inline
                  input(type="radio" class="form-check-input" id="statusInactive" name="status" value="inactive")
                  label(for="statusInactive" class="form-check-label") Dừng
        
        .form-group.mt-3
          button(type="submit" class="btn btn-primary px-4") XÁC NHẬN TẠO