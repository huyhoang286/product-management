extends ../../layouts/default.pug

block main
    h1(class="mb-4") Thùng rác

    .card.mb-3
        .card-header Danh sách sản phẩm đã xóa
        .card-body
            form(
                form-change-multi
                data-path="/admin/products/change-multi-trash"
            )
                .d-flex.align-items-start
                    .form-group
                        select(name="type" class="form-control")
                            option(disabled selected) -- Chọn hành động --
                            option(value="restore-all") Khôi phục tất cả
                            option(value="delete-permanent-all") Xóa vĩnh viễn
                    button(type="submit" class="btn btn-primary") Áp dụng

            table(
                class="table table-hover table-sm"
                checkbox-multi
            )
                thead
                    tr
                        th 
                            input(type="checkbox" name="checkall")
                        th STT
                        th Hình ảnh
                        th Tiêu đề
                        th Thời gian xóa
                        th Hành động
                tbody
                    if products.length > 0
                        each item, index in products
                            tr
                                td  
                                    input(type="checkbox" name="id" value=item.id)
                                td #{index + 1}
                                td
                                    img(src=item.thumbnail, alt=item.title, width="100px", height="auto")
                                td #{item.title}
                                td 
                                    if item.deletedAt
                                        | #{item.deletedAt.toLocaleString("vi-VN")}
                                td
                                    button(
                                        class="btn btn-info btn-sm"
                                        button-restore
                                        data-id=item.id
                                    ) Khôi phục
                                    button(
                                        class="btn btn-danger btn-sm ml-1"
                                        button-delete-permanent
                                        data-id=item.id
                                    ) Xóa vĩnh viễn
                    else 
                        tr 
                            td(colspan="5" class="text-center") Thùng rác trống.
                        
    script(src="/admin/js/product.js") 