extends ../../layouts/default.pug
include ../../mixins/search.pug
include ../../mixins/pagination.pug

block main
    h1.mb-4 Danh sách sản phẩm

    .card.mb-3
        .card-header Bộ lọc và Tìm kiếm
        .card-body
            .row
                .col-3
                    each item in filterStatus
                        button(
                            class=`btn btn-sm ml-1 btn-outline-success ${item.class}`
                            button-status=item.status
                        ) #{item.name}
                .col-5
                    +search(keyword)
                .col-4
                    div(sort)
                        select.form-control(name="sort" sort-select)
                            option(value="") -- Sắp xếp --
                            option(value="createdAt-desc") Mới nhất
                            option(value="price-desc") Giá giảm dần
                            option(value="price-asc") Giá tăng dần
                            option(value="title-asc") Tiêu đề A - Z
                            option(value="title-desc") Tiêu đề Z - A

    .card.mb-3
        .card-header Danh sách
        .card-body
            .row.mb-3 
                .col-8 
                    form(
                        form-change-multi
                        data-path="/admin/products/change-multi"
                    )
                        .d-flex.align-items-start
                            .form-group
                                select(name="type" class="form-control")
                                    option(disabled selected) -- Chọn hành động --
                                    option(value="active") Hoạt động
                                    option(value="inactive") Dừng hoạt động
                                    option(value="delete-all") Xóa tất cả
                            button(type="submit" class="btn btn-primary") Áp dụng
                if(role.permissions.includes("products_create"))
                    .col-4.text-right 
                        a(
                            href=`${prefixAdmin}/products/create`
                            class="btn btn-outline-success"
                        ) + Thêm mới
            
            table(
                class="table table-hover table-sm"
                checkbox-multi
            )
                thead
                    tr
                        th 
                            input(type="checkbox" name="checkall")
                        th STT
                        th Hình ảnh
                        th Tiêu đề
                        th Giá
                        th Trạng thái
                        th Hành động
                tbody
                    each item, index in products
                        tr
                            td 
                                input(type="checkbox" name="id" value=item.id)
                            td #{index+1}
                            td
                                img(
                                    src=item.thumbnail
                                    alt=item.title
                                    width="100px"
                                    height="auto"
                                )
                            td #{item.title}
                            td #{item.price}$
                            td
                                if(role.permissions.includes("products_edit"))
                                    if(item.status == "active")
                                        a(
                                            href="javascript:;" 
                                            data-status=item.status
                                            data-id=item.id
                                            button-change-status
                                            class="badge badge-success"
                                        ) Hoạt động
                                    else    
                                        a(
                                            href="javascript:;" 
                                            data-status=item.status
                                            data-id=item.id
                                            button-change-status
                                            class="badge badge-danger"
                                        ) Dừng hoạt động
                                else 
                                    if(item.status == "active")
                                        span(class="badge badge-success") Hoạt động
                                    else    
                                        span(class="badge badge-danger") Dừng hoạt động
                            td
                                if(role.permissions.includes("products_edit"))
                                    a(
                                        href=`${prefixAdmin}/products/edit/${item.id}`
                                        class="btn btn-warning btn-sm"
                                    ) Sửa
                                if(role.permissions.includes("products_delete"))
                                    button(
                                        class="btn btn-danger btn-sm ml-1"
                                        button-delete 
                                        data-id=item.id
                                        ) Xóa
            +pagination(pagination)
    

    script(src="/admin/js/product.js") 