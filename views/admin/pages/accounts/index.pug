extends ../../layouts/default.pug

block main
  h1(class="mb-4") Danh sách tài khoản

  .card.mb-3
    .card-header Danh sách
    .card-body
      .row
        .col-8
        .col-4.text-right
          a(
            href=`${prefixAdmin}/accounts/create`
            class="btn btn-outline-success"
          ) + Thêm mới

      table(
        class="table table-hover table-sm mt-3"
      )
        thead
          tr
            th STT
            th Avatar
            th Họ tên
            th Phân quyền
            th Email
            th Trạng thái
            th Hành động

        tbody
          if(records.length > 0)
            each item, index in records
              tr
                td #{index + 1}
                td
                  img(
                    src=item.avatar
                    alt=item.fullName
                    width="50px"
                    height="50px"
                    style="border-radius: 50%; object-fit: cover;"
                  )
                td #{item.fullName}
                td #{item.role.title}
                td #{item.email}
                td
                  if (item.status === "active")
                    button(
                        class="badge badge-success"
                        button-change-status-account
                        data-status="active"
                        data-id=item.id
                    ) Hoạt động
                  else
                    button(
                        class="badge badge-danger"
                        button-change-status-account
                        data-status="inactive"
                        data-id=item.id
                    ) Dừng hoạt động
                td
                  a(
                    class="btn btn-warning btn-sm"
                    href=`${prefixAdmin}/accounts/edit/${item.id}`
                  ) Sửa
                  button(
                    class="btn btn-danger btn-sm ml-1"
                    button-delete-account
                    data-id=item.id
                  ) Xóa
          else
            tr
              td(colspan="7" class="text-center") Chưa có tài khoản nào được tạo.