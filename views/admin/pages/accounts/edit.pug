extends ../../layouts/default.pug

block main
  h1(class="mb-4") Chỉnh sửa tài khoản

  form(
    id="form-edit-account"
    data-id=data.id
  )
    .form-group
      label(for="fullName") Họ tên *
      input(
        type="text"
        class="form-control"
        id="fullName"
        name="fullName"
        required
        value=data.fullName
      )
    .form-group
      label(for="email") Email *
      input(
        type="email"
        class="form-control"
        id="email"
        name="email"
        required
        value=data.email
      )
    .form-group
      label(for="password") Mật khẩu 
      input(
        type="password"
        class="form-control"
        id="password"
        name="password"
        placeholder="Chỉ điền khi muốn đổi mật khẩu mới"
      )
    .form-group
      label(for="phone") Số điện thoại
      input(
        type="text"
        class="form-control"
        id="phone"
        name="phone"
        value=data.phone
      )
    .form-group(upload-image)
      label(for="avatar") Avatar
      input(
        type="file"
        class="form-control-file"
        id="avatar"
        name="avatar"
        accept="image/*"
        upload-image-input
      )
      div(class="image-preview-container")
        img(
          src=data.avatar
          class="image-preview"
          upload-image-preview
        )
        span(class="close-image" upload-image-close) x
    
    .form-group
      label(for="role_id") Phân quyền
      select(name="role_id" id="role_id" class="form-control")
        option(disabled) -- Chọn nhóm quyền --
        each item in roles
          option(
            value=item.id 
            selected=(item.id == data.role_id ? true : false)
          ) #{item.title}

    .form-group.form-check.form-check-inline
      input(
        type="radio"
        class="form-check-input"
        id="statusActive"
        name="status"
        value="active"
        checked=(data.status == "active" ? true : false)
      )
      label(for="statusActive" class="form-check-label") Hoạt động
    .form-group.form-check.form-check-inline
      input(
        type="radio"
        class="form-check-input"
        id="statusInActive"
        name="status"
        value="inactive"
        checked=(data.status == "inactive" ? true : false)
      )
      label(for="statusInActive" class="form-check-label") Dừng hoạt động

    .form-group
      button(
        type="submit"
        class="btn btn-primary mt-3"
      ) Cập nhật

