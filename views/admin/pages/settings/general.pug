extends ../../layouts/default.pug

block main
    h1.mb-4 Cấu hình chung

    form(
        action=`${prefixAdmin}/settings/general?_method=PATCH`
        method="POST"
        enctype="multipart/form-data"
    )
        .row
            //- CỘT TRÁI: THÔNG TIN VÀ CẤU HÌNH HIỂN THỊ
            .col-md-6
                .card.mb-4
                    .card-header Thông tin cơ bản
                    .card-body
                        .form-group
                            label Tên website
                            input(type="text" class="form-control" name="websiteName" value=(settingGeneral.websiteName || ""))
                        .form-group
                            label Số điện thoại
                            input(type="text" class="form-control" name="phone" value=(settingGeneral.phone || ""))
                        .form-group
                            label Email
                            input(type="email" class="form-control" name="email" value=(settingGeneral.email || ""))
                        .form-group
                            label Địa chỉ
                            input(type="text" class="form-control" name="address" value=(settingGeneral.address || ""))
                        .form-group
                            label Câu chuyện của chúng tôi (Trang giới thiệu)
                            textarea(
                                class="form-control"
                                name="ourStory"
                                rows="5"
                            ) #{settingGeneral ? settingGeneral.ourStory : ""}
                
                //- CẤU HÌNH TRANG CHỦ
                .card.mb-4
                    .card-header.bg-info.text-white 
                        i.fas.fa-home 
                        |  Cấu hình hiển thị Trang Chủ
                    .card-body
                        .form-group
                            label Số sản phẩm / 1 Hàng
                            input(type="number" min="1" max="6" class="form-control" name="productsPerRow" value=(settingGeneral.productsPerRow || 4))
                        .form-group
                            label Số sản phẩm mục "Sản phẩm mới"
                            input(type="number" min="1" class="form-control" name="productsHomeNew" value=(settingGeneral.productsHomeNew || 8))
                        .form-group
                            label Số sản phẩm mục "Sản phẩm bán chạy"
                            input(type="number" min="1" class="form-control" name="productsHomeBestSeller" value=(settingGeneral.productsHomeBestSeller || 8))

                //- CẤU HÌNH TRANG SẢN PHẨM 
                .card.mb-4
                    .card-header.bg-secondary.text-white 
                        i.fas.fa-th-list
                        |  Cấu hình Trang Sản Phẩm
                    .card-body
                        .form-group
                            label Số lượng sản phẩm / 1 Trang (Phân trang)
                            input(type="number" min="1" class="form-control" name="productsPerPage" value=(settingGeneral.productsPerPage || 12))

            //- QUẢN LÝ HÌNH ẢNH (LOGO & BANNER)
            .col-md-6
                //- QUẢN LÝ LOGO
                .card.mb-4
                    .card-header Logo Website
                    .card-body
                        .form-group(upload-image)
                            input(type="file" class="form-control-file" name="logo" accept="image/*" upload-image-input)
                            img(src=(settingGeneral.logo || "") upload-image-preview class="image-preview mt-2" width="150px")
                            span.close-image x

                //- QUẢN LÝ BANNERS ĐỘNG
                .card.mb-4
                    .card-header.d-flex.justify-content-between.align-items-center.bg-primary.text-white
                        span 
                            i.fas.fa-images
                            |  Hình ảnh Banner
                        button.btn.btn-sm.btn-success(type="button" onclick="addBanner()") + Thêm Banner
                    .card-body#banner-container
                        if settingGeneral && settingGeneral.banners && settingGeneral.banners.length > 0
                            each banner in settingGeneral.banners
                                .banner-item.border.p-3.mb-3.d-flex.align-items-center.bg-light
                                    .flex-grow-1
                                        input(type="hidden" name="bannerUrls" value=banner)
                                        input.form-control-file.d-none(type="file" name="banners" accept="image/*" onchange="previewBanner(this)")
                                        img.mt-2.preview-img(src=banner width="100%" style="max-height: 150px; object-fit: cover;")
                                    .action-buttons.ml-3.d-flex.flex-column.gap-2
                                        button.btn.btn-info.btn-sm.mb-1(type="button" onclick="triggerFileInput(this)") Thay ảnh
                                        button.btn.btn-secondary.btn-sm.mb-1(type="button" onclick="moveUp(this)") Lên
                                        button.btn.btn-secondary.btn-sm.mb-1(type="button" onclick="moveDown(this)") Xuống
                                        button.btn.btn-danger.btn-sm(type="button" onclick="removeBanner(this)") Xóa
                        else
                            p.text-muted.text-center#empty-banner-msg Chưa có banner nào. Hãy bấm "Thêm Banner"!

        .form-group.mt-3.text-center
            button(type="submit" class="btn btn-primary btn-lg px-5") Cập nhật cấu hình

    script.
        function addBanner() {
            const container = document.getElementById('banner-container');
            
            const emptyText = document.getElementById('empty-banner-msg');
            if(emptyText) emptyText.remove();

            const div = document.createElement('div');
            div.className = "banner-item border p-3 mb-3 d-flex align-items-center bg-light";
            div.innerHTML = `
                <div class="flex-grow-1">
                    <input type="hidden" name="bannerUrls" value="">
                    <input type="file" class="form-control-file d-none" name="banners" accept="image/*" onchange="previewBanner(this)">
                    <img class="mt-2 preview-img" src="" width="100%" style="display:none; max-height: 150px; object-fit: cover;">
                </div>
                <div class="action-buttons ml-3 d-flex flex-column gap-2">
                    <button class="btn btn-info btn-sm mb-1" type="button" onclick="triggerFileInput(this)">Chọn ảnh</button>
                    <button class="btn btn-secondary btn-sm mb-1" type="button" onclick="moveUp(this)">Lên</button>
                    <button class="btn btn-secondary btn-sm mb-1" type="button" onclick="moveDown(this)">Xuống</button>
                    <button class="btn btn-danger btn-sm" type="button" onclick="removeBanner(this)">Xóa</button>
                </div>
            `;
            container.appendChild(div);
            
            div.querySelector('input[type="file"]').click();
        }

        function removeBanner(button) {
            button.closest('.banner-item').remove();
        }

        function triggerFileInput(button) {
            button.closest('.banner-item').querySelector('input[type="file"]').click();
        }

        function previewBanner(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const item = input.closest('.flex-grow-1');
                    const img = item.querySelector('.preview-img');
                    img.src = e.target.result;
                    img.style.display = "block";
                    
                    const urlInput = item.querySelector('input[name="bannerUrls"]');
                    if (urlInput) urlInput.value = ""; 
                }
                reader.readAsDataURL(input.files[0]);
                
                const btnInfo = input.closest('.banner-item').querySelector('.btn-info');
                if (btnInfo) btnInfo.innerText = "Thay ảnh";
            }
        }

        function moveUp(button) {
            const item = button.closest('.banner-item');
            const previous = item.previousElementSibling;
            if (previous && previous.classList.contains('banner-item')) {
                item.parentNode.insertBefore(item, previous);
            }
        }

        function moveDown(button) {
            const item = button.closest('.banner-item');
            const next = item.nextElementSibling;
            if (next && next.classList.contains('banner-item')) {
                item.parentNode.insertBefore(next, item);
            }
        }