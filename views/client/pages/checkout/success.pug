extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
  .container.my-5
    .row.justify-content-center
      .col-md-10
        .text-center.mb-5
          h1.text-success.display-4 <i class="fas fa-check-circle"></i> ĐẶT HÀNG THÀNH CÔNG!
          p.lead.mt-3 Cảm ơn bạn đã tin tưởng mua sắm. Đơn hàng của bạn đang được xử lý.
          p Mã đơn hàng: <b class="text-primary">#{order.id}</b>
        
        .row
          //- THÔNG TIN KHÁCH HÀNG
          .col-md-5.mb-4
            .card.h-100.shadow-sm
              .card-header.bg-info.text-white 
                h5.mb-0 <i class="fas fa-user mr-2"></i> Người nhận hàng
              .card-body
                p.mb-2 <b>Họ tên:</b> #{order.userInfo.fullName}
                p.mb-2 <b>Điện thoại:</b> #{order.userInfo.phone}
                p.mb-2 <b>Địa chỉ:</b> #{order.userInfo.address}
                if(order.userInfo.note)
                  p.mb-0 <b>Ghi chú:</b> #{order.userInfo.note}
                hr
                p.mb-0 <b>Thanh toán:</b> 
                  span.badge.badge-pill.badge-primary.ml-2 #{order.payment_method === 'cod' ? 'COD' : 'VietQR'}
          
          //- CHI TIẾT HÓA ĐƠN
          .col-md-7.mb-4
            .card.h-100.shadow-sm
              .card-header.bg-dark.text-white 
                h5.mb-0 <i class="fas fa-file-invoice-dollar mr-2"></i> Chi tiết thanh toán
              .card-body.p-0
                .table-responsive
                  table.table.table-borderless.mb-0
                    thead.bg-light.border-bottom
                      tr
                        th.pl-4 Sản phẩm
                        th.text-center SL
                        th.text-right.pr-4 Tổng
                    tbody
                      - var originalTotal = 0
                      - var productDiscountTotal = 0
                      
                      if (order.products.length > 0)
                        each item in order.products
                          if (item.productInfo)
                            - var itemOriginalTotal = item.price * item.quantity
                            - var priceNew = Math.round(item.price * (1 - item.discountPercentage/100))
                            - var itemTotal = priceNew * item.quantity
                            - originalTotal += itemOriginalTotal
                            - productDiscountTotal += (itemOriginalTotal - itemTotal)
                            
                            tr.border-bottom
                              td.py-3.pl-4
                                .d-flex.align-items-center
                                  img(src=item.productInfo.thumbnail width="45px" class="mr-3 rounded")
                                  span.small.font-weight-bold #{item.productInfo.title}
                              td.py-3.text-center.align-middle x#{item.quantity}
                              td.py-3.text-right.pr-4.align-middle #{itemTotal.toLocaleString("vi-VN")}đ
                
                .p-4.bg-light.text-right.border-top
                  .d-flex.justify-content-between.mb-1
                    span.text-muted Tiền hàng (Giá gốc):
                    span #{originalTotal.toLocaleString("vi-VN")}đ
                  
                  if (productDiscountTotal > 0)
                    .d-flex.justify-content-between.mb-1.text-primary
                      span Giảm giá từ sản phẩm:
                      span -#{productDiscountTotal.toLocaleString("vi-VN")}đ
                  
                  - var subTotal = originalTotal - productDiscountTotal
                  .d-flex.justify-content-between.mb-1.font-weight-bold
                    span Tạm tính:
                    span #{subTotal.toLocaleString("vi-VN")}đ
                  
                  if (order.discount_amount > 0)
                    .d-flex.justify-content-between.mb-1.text-success
                      span Giảm giá từ Voucher:
                      span -#{order.discount_amount.toLocaleString("vi-VN")}đ
                  
                  hr
                  .d-flex.justify-content-between.align-items-center
                    h5.mb-0 Tổng thanh toán:
                    h4.mb-0.text-danger.font-weight-bold #{order.totalPrice.toLocaleString("vi-VN")}đ
                
        .text-center.mt-4
          a(href="/products" class="btn btn-primary btn-lg px-5 rounded-pill shadow") <i class="fas fa-shopping-cart mr-2"></i> Tiếp tục mua sắm