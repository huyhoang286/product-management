extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
    .container.my-5
        .row
            .col-12
                +box-head("Thanh toán đơn hàng")

        .row.mt-4
            .col-lg-7
                .card.mb-4
                    .card-header.bg-dark.text-white Thông tin tóm tắt đơn hàng
                    .card-body
                        table.table.table-sm.table-borderless
                            thead
                                tr
                                    th Sản phẩm
                                    th Size
                                    th SL
                                    th Thành tiền
                            tbody
                                if (cartDetail.products.length > 0)
                                    each item in cartDetail.products
                                        if (item.productInfo)
                                            tr.border-bottom
                                                td.py-3 
                                                    img(src=item.productInfo.thumbnail width="50px" class="mr-2 rounded")
                                                    | #{item.productInfo.title}
                                                td.py-3 #{item.variantInfo ? item.variantInfo.size : ""}
                                                td.py-3 #{item.quantity}
                                                td.py-3.font-weight-bold.text-danger #{item.totalPrice.toLocaleString("vi-VN")} VNĐ
                        
                        h5.text-right.mt-3 Tổng cộng: <span class="text-danger font-weight-bold">#{cartDetail.totalPrice.toLocaleString("vi-VN")} VNĐ</span>

            .col-lg-5
                .card
                    .card-header.bg-primary.text-white Thông tin giao hàng
                    .card-body
                        form(form-checkout)
                            input(type="hidden" name="selectedItemsString" value=selectedItemsString)
                            .form-group
                                label(for="fullName") Họ và tên
                                input.form-control(type="text" id="fullName" name="fullName" value=(user ? user.fullName : "") required)
                            .form-group
                                label(for="phone") Số điện thoại
                                input.form-control(type="text" id="phone" name="phone" value=(user ? user.phone : "") required)
                            .form-group
                                label(for="address") Địa chỉ giao hàng
                                input.form-control(type="text" id="address" name="address" value=(user ? user.address : "") required)
                            
                            hr
                            label.font-weight-bold Phương thức thanh toán
                            .form-check.mb-2
                                input.form-check-input(type="radio" name="payment_method" id="cod" value="cod" checked)
                                label.form-check-label(for="cod") Thanh toán khi nhận hàng (COD)
                            
                            .form-check.mb-4
                                input.form-check-input(type="radio" name="payment_method" id="vietqr" value="vietqr")
                                label.form-check-label(for="vietqr") Chuyển khoản ngân hàng (Online / VietQR)

                            button.btn.btn-success.btn-block.btn-lg(type="submit") THANH TOÁN NGAY