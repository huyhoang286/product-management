extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
    //- HERO BANNER 
    .hero-section.mb-5
        #heroCarousel.carousel.slide(data-ride="carousel" data-interval="4000")
            ol.carousel-indicators
                li.active(data-target="#heroCarousel" data-slide-to="0")
                li(data-target="#heroCarousel" data-slide-to="1")
                li(data-target="#heroCarousel" data-slide-to="2")

            .carousel-inner
                .carousel-item.active
                    .banner-wrapper(style="position: relative; background-color: #000;")
                        img.d-block.w-100(src="/images/banner1.jpg" alt="Bứt Phá Tốc Độ" style="height: 550px; object-fit: cover; opacity: 0.6;")
                        .carousel-caption.d-none.d-md-block(style="top: 50%; transform: translateY(-50%); bottom: auto; left: 8%; text-align: left; text-shadow: 2px 2px 8px rgba(0,0,0,0.8);")
                            h1.display-3.font-weight-bold.text-uppercase(style="letter-spacing: 2px;") Bứt Phá Tốc Độ
                            p.lead.mb-4(style="font-size: 1.3rem;") Khám phá bộ sưu tập Nike Mercurial mới nhất mùa giải
                            a.btn.btn-primary.btn-lg.px-5.py-3.font-weight-bold(href="/products" style="border-radius: 30px; text-transform: uppercase;") Mua Ngay

                .carousel-item
                    .banner-wrapper(style="position: relative; background-color: #000;")
                        img.d-block.w-100(src="/images/banner2.png" alt="Kiểm Soát Thế Trận" style="height: 550px; object-fit: cover; opacity: 0.6;")
                        .carousel-caption.d-none.d-md-block(style="top: 50%; transform: translateY(-50%); bottom: auto; right: 8%; text-align: right; text-shadow: 2px 2px 8px rgba(0,0,0,0.8);")
                            h1.display-3.font-weight-bold.text-uppercase(style="letter-spacing: 2px;") Kiểm Soát Trận Đấu
                            p.lead.mb-4(style="font-size: 1.3rem;") Dòng giày Adidas Predator với độ bám và kiểm soát đỉnh cao
                            a.btn.btn-danger.btn-lg.px-5.py-3.font-weight-bold(href="/products?category=fg" style="border-radius: 30px; text-transform: uppercase;") Xem Chi Tiết

                .carousel-item
                    .banner-wrapper(style="position: relative; background-color: #000;")
                        img.d-block.w-100(src="https://images.unsplash.com/photo-1579952363873-27f3bade9f55?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" alt="Sale Khủng" style="height: 550px; object-fit: cover; opacity: 0.6;")
                        .carousel-caption.d-none.d-md-block(style="top: 50%; transform: translateY(-50%); bottom: auto; text-align: center; text-shadow: 2px 2px 8px rgba(0,0,0,0.8);")
                            h1.display-3.font-weight-bold.text-uppercase.text-warning(style="letter-spacing: 2px;") Sale Khủng Cuối Tuần
                            p.lead.mb-4(style="font-size: 1.3rem;") Giảm giá lên đến 50% cho các mẫu giày Futsal (IC)
                            a.btn.btn-warning.btn-lg.px-5.py-3.font-weight-bold(href="/products?category=ic" style="border-radius: 30px; text-transform: uppercase;") Săn Sale Ngay

            a.carousel-control-prev(href="#heroCarousel" role="button" data-slide="prev" style="width: 5%;")
                span.carousel-control-prev-icon(aria-hidden="true" style="width: 3rem; height: 3rem;")
                span.sr-only Previous
            a.carousel-control-next(href="#heroCarousel" role="button" data-slide="next" style="width: 5%;")
                span.carousel-control-next-icon(aria-hidden="true" style="width: 3rem; height: 3rem;")
                span.sr-only Next

    //- DANH MỤC NHANH 
    .container.mb-5
        .row.text-center
            .col-md-3.col-6.mb-3
                a(href="/products?category=tf" class="text-decoration-none text-dark")
                    .p-4.border.rounded.shadow-sm.bg-light(style="transition: all 0.3s;height: 146px" onmouseover="this.classList.add('shadow')" onmouseout="this.classList.remove('shadow')")
                        img.mb-2(src="/icon/tf.png" alt="TF" style="height: 40px; object-fit: contain;")
                        h5.mb-0 Giày Sân Cỏ Nhân Tạo (TF)
                        
            .col-md-3.col-6.mb-3
                a(href="/products?category=fg" class="text-decoration-none text-dark")
                    .p-4.border.rounded.shadow-sm.bg-light(style="transition: all 0.3s;height: 146px" onmouseover="this.classList.add('shadow')" onmouseout="this.classList.remove('shadow')")
                        img.mb-2(src="/icon/fg.png" alt="FG" style="height: 40px; object-fit: contain;")
                        h5.mb-0 Giày Sân Cỏ Tự Nhiên (FG)
                        
            .col-md-3.col-6.mb-3
                a(href="/products?category=ic" class="text-decoration-none text-dark")
                    .p-4.border.rounded.shadow-sm.bg-light(style="transition: all 0.3s;height: 146px" onmouseover="this.classList.add('shadow')" onmouseout="this.classList.remove('shadow')")
                        img.mb-2(src="/icon/ic.png" alt="IC" style="height: 40px; object-fit: contain;")
                        h5.mb-0 Giày Futsal (IC)
                        
            .col-md-3.col-6.mb-3
                a(href="/products?category=accessories" class="text-decoration-none text-dark")
                    .p-4.border.rounded.shadow-sm.bg-light(style="transition: all 0.3s;height: 146px" onmouseover="this.classList.add('shadow')" onmouseout="this.classList.remove('shadow')")
                        img.mb-2(src="/icon/socks.png" alt="Phụ Kiện" style="height: 40px; object-fit: contain;")
                        h5.mb-0 Phụ Kiện Bóng Đá
    //- SẢN PHẨM GIẢM GIÁ 
    .container.mb-5
        .row
            .col-12
                +box-head("Sản Phẩm Giảm Giá Sốc")
        .row
            if productsFeatured && productsFeatured.length > 0
                each item in productsFeatured
                    .col-4.mb-3
                        .product-item
                            .inner-image
                                a(href=`/products/${item.slug}`)
                                    img(src=item.thumbnail, alt=item.title)
                            .inner-content
                                h3.inner-title 
                                    a(href=`/products/${item.slug}`) #{item.title}
                                .inner-price-new #{item.priceNew ? item.priceNew.toLocaleString("vi-VN") : item.price.toLocaleString("vi-VN")} VNĐ
                                if (item.discountPercentage > 0)
                                    .inner-price-old #{item.price.toLocaleString("vi-VN")} VNĐ
                                    .inner-discount -#{item.discountPercentage}%

    //- SẢN PHẨM MỚI NHẤT 
    .container.mb-5
        .row
            .col-12
                +box-head("Hàng Mới Về")
        .row
            if productsNew && productsNew.length > 0
                each item in productsNew
                    .col-4.mb-3
                        .product-item
                            .inner-image
                                a(href=`/products/${item.slug}`)
                                    img(src=item.thumbnail, alt=item.title)
                            .inner-content
                                h3.inner-title 
                                    a(href=`/products/${item.slug}`) #{item.title}
                                .inner-price-new #{item.priceNew ? item.priceNew.toLocaleString("vi-VN") : item.price.toLocaleString("vi-VN")} VNĐ
                                if (item.discountPercentage > 0)
                                    .inner-price-old #{item.price.toLocaleString("vi-VN")} VNĐ
                                    .inner-discount -#{item.discountPercentage}%