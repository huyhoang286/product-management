extends ../../layouts/default.pug

block main
    .container.my-5
        .row.justify-content-center
            .col-md-5
                .card.shadow-sm
                    .card-header.bg-success.text-white.text-center
                        h4 XÁC THỰC MÃ OTP
                    .card-body.p-4
                        p.text-center Vui lòng nhập mã OTP gồm 6 chữ số đã được gửi đến email <br> <b>#{email}</b>.
                        
                        form(form-otp)
                            input(type="hidden" name="email" value=email)
                            .form-group.mt-4.mb-4
                                input.form-control.text-center(type="text" name="otp" required maxlength="6" style="font-size: 28px; letter-spacing: 15px;")
                            button.btn.btn-success.btn-block.btn-lg(type="submit") XÁC NHẬN