extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/sub-menu.pug 
include ../../mixins/pagination.pug

block main
  .container.mb-5
    .row.mt-4
      .col-lg-3.mb-4
        .card.mb-4.shadow-sm.border-0
          .card-header.bg-primary.text-white.font-weight-bold
            i.fas.fa-list.mr-2
            | DANH MỤC SẢN PHẨM
          .card-body.p-0
            if layoutProductsCategory
              +sub-menu(layoutProductsCategory, "/products")

        .card.mb-4.shadow-sm.border-0
          .card-header.bg-success.text-white.font-weight-bold
            i.fas.fa-filter.mr-2
            | LỌC THEO GIÁ
          .card-body
            form(id="form-filter-price")
              .form-group.mb-2
                label(for="minPrice" class="small font-weight-bold text-muted") Giá từ (VNĐ)
                input.form-control.form-control-sm(
                  type="number" 
                  id="minPrice" 
                  name="minPrice" 
                  placeholder="VD: 100000" 
                  min="0" 
                  value=minPrice
                )
              .form-group.mb-3
                label(for="maxPrice" class="small font-weight-bold text-muted") Đến (VNĐ)
                input.form-control.form-control-sm(
                  type="number" 
                  id="maxPrice" 
                  name="maxPrice" 
                  placeholder="VD: 500000" 
                  min="0" 
                  value=maxPrice
                )
              .d-flex.justify-content-between
                button.btn.btn-outline-success.btn-sm.w-50.mr-1(type="submit" title="Áp dụng lọc") 
                  i.fas.fa-check
                
                button.btn.btn-outline-secondary.btn-sm.w-50.ml-1(type="button" id="btn-clear-price" title="Hủy lọc giá") 
                  i.fas.fa-undo-alt.mr-1
                  | Hủy

      .col-lg-9
        .row.mb-3
          .col-12.d-flex.justify-content-between.align-items-center
            if (keyword)
              +box-head(`Kết quả tìm kiếm: "${keyword}"`)
            else 
              +box-head(pageTitle ? pageTitle : "Tất Cả Sản Phẩm")
            
            .sort-box.d-flex.align-items-center
              span.mr-2.font-weight-bold Lọc theo:
              select.form-control.shadow-sm(name="sort" sort-select style="border-radius: 20px; cursor: pointer;")
                option(value="newest" selected=(sort === 'newest' ? true : false)) Hàng mới về
                option(value="best-selling" selected=(sort === 'best-selling' ? true : false)) Bán chạy nhất
                option(value="price-asc" selected=(sort === 'price-asc' ? true : false)) Giá: Thấp đến Cao
                option(value="price-desc" selected=(sort === 'price-desc' ? true : false)) Giá: Cao đến Thấp

        if products && products.length > 0
          .row
            each item in products
              .col-md-4.mb-4
                .product-card.card.h-100.border-0.shadow-sm
                  .position-relative.overflow-hidden
                    if (item.discountPercentage > 0)
                      span.badge-discount.position-absolute -#{item.discountPercentage}%
                    
                    a(href=`/products/${item.slug}`)
                      img.card-img-top(src=item.thumbnail, alt=item.title)
                  
                  .card-body.p-3
                    h6.card-title.font-weight-bold 
                      a.text-dark(href=`/products/${item.slug}`) #{item.title}
                    
                    .d-flex.align-items-center
                      span.price-new #{item.newPrice ? item.newPrice.toLocaleString("vi-VN") : item.price} VNĐ
                      if (item.discountPercentage > 0)
                        small.price-old #{item.price.toLocaleString("vi-VN")} VNĐ
                  
                  .card-footer.bg-white.border-0.p-3.pt-0
                    a.btn.btn-outline-primary.btn-sm.btn-block.rounded-pill(href=`/products/${item.slug}`) Xem chi tiết
          
          .row.mt-4
            .col-12.d-flex.justify-content-center
              +pagination(pagination)

        else
          .alert.alert-warning.text-center.p-5.shadow-sm.w-100
            i.fas.fa-box-open.fa-3x.mb-3.text-muted
            if (keyword)
              h4 Rất tiếc, không tìm thấy sản phẩm nào phù hợp với từ khóa "<b class="text-danger">#{keyword}</b>"
            else
              h4 Hiện tại danh mục này chưa có sản phẩm nào!